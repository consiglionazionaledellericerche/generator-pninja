<?php

namespace App\Http\Middleware;

use Closure;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Session;
use App\Traits\HandlesUserRoles;

class AccessControl
{
    use HandlesUserRoles;
    public function handle(Request $request, Closure $next)
    {
        $resource = str_replace('Controller', '', class_basename(get_class($request->route()->getController())));
        $method = strtolower($request->method());
        $action = match($method) {
            'get' => 'read',
            'post' => 'create',
            'put','patch' => 'update',
            'delete' => 'delete'
        };
        if ($resource === 'RecordLock' && $request->route('type') && !str_ends_with($request->path(), '/force')) {
            $map = config('locking.models', []);
            $type = $request->route('type');
            $resource = isset($map[$type]) ? class_basename($map[$type]) : 'RecordLock';
            $action = 'update';
        }
        $result = $this->userHasPermission($resource, $action);
        $sessionUser = Session::get('authenticated_user');
        $username = $sessionUser['preferred_username'] ?? null;
        if ($resource !== 'Log' && app()->environment("local")) \Log::debug("AccessControl: User '{$username}' attempting to {$action} on {$resource} (URL: {$request->fullUrl()}) - Permission: " . ($result ? 'granted' : 'denied'));
        if ($username && !$result && in_array($resource, ['AcRule', 'Audit', 'Seeder', 'Migrations', 'RecordLock', 'SearchReindex', 'Log'])) {
            \Log::warning("AccessControl: User '{$username}' attempting to {$action} on {$resource} (URL: {$request->fullUrl()}) - Permission: " . ($result ? 'granted' : 'denied'));
        }
        if (!$result) {
            return response()->json([
                'error' => 'Forbidden',
                'message' => "Permission denied for {$action} on {$resource}"
            ], 403);
        }
        return $next($request);
    }
}