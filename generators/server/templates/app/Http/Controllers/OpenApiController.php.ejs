<?php

namespace App\Http\Controllers;

use Illuminate\Http\Request;
use Illuminate\Support\Facades\File;

class OpenApiController extends Controller
{
    public function show()
    {
        $path = resource_path('openapi.json');

        if (!File::exists($path)) {
            return response()->json(['error' => 'OpenAPI spec not found'], 404);
        }

        $keycloakBaseUrl = rtrim(env('KEYCLOAK_BASE_URL', ''), '/');
        $keycloakRealm   = env('KEYCLOAK_REALM', '');
        $keycloakClientId = env('KEYCLOAK_CLIENT_ID', '');

        $base = "{$keycloakBaseUrl}/realms/{$keycloakRealm}/protocol/openid-connect";

        $spec = File::get($path);
        $spec = str_replace('__KEYCLOAK_AUTH_URL__',  "{$base}/auth",  $spec);
        $spec = str_replace('__KEYCLOAK_TOKEN_URL__', "{$base}/token", $spec);
        $spec = str_replace('__KEYCLOAK_CLIENT_ID__', $keycloakClientId, $spec);

        return response($spec, 200)
            ->header('Content-Type', 'application/json');
    }
}
