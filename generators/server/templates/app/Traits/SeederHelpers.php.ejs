<?php

namespace App\Traits;

use Illuminate\Support\Facades\File;
use Illuminate\Support\Facades\Log;

trait SeederHelpers
{
    private function seedFromCsv(string $modelClass): bool
    {
        $csvPath = database_path("seeders/csv/" . ((new \ReflectionClass($modelClass))->getShortName()) . ".csv");
        if (!File::exists($csvPath)) return false;
        try {
            $csv = array_map('str_getcsv', file($csvPath));
            $headers = array_shift($csv);

            foreach ($csv as $row) {
                if (empty(array_filter($row))) continue;

                $data = array_combine($headers, $row);
                $data = array_filter($data, fn($value) => $value !== '' && $value !== null);
                $data = $this->resolveBlobFields($data, $this->blobFields ?? []);

                try {
                    $modelClass::create($data);
                } catch (\Throwable $th) {
                    $message = "Failed to create {$modelClass}. Error: " . $th->getMessage();
                    $this->command?->error($message);
                    Log::error($message);
                }
            }
            return true;
        } catch (\Throwable $th) {
            $message = "seedFromCsv failed for {$modelClass}: " . $th->getMessage();
            $this->command?->error($message);
            Log::error($message);
            return false;
        }
    }

    /**
     * Resolve blob fields in a CSV row.
     *
     * Only columns listed in $blobFields are treated as blobs.
     * Each value is interpreted as:
     * - starts with '{' → JSON blob object {data, type, name, size}
     * - starts with 'data:' → data URI (data:<mime>;base64,<data>)
     * - looks like a filesystem path or has a file extension → file read from disk
     * - valid plain base64 string → decoded and wrapped in a blob object
     *
     * The resolved value is always an array {data, type, name, size} compatible
     * with BlobCast, or null if resolution fails.
     */
    private function resolveBlobFields(array $data, array $blobFields): array
    {
        foreach ($blobFields as $key) {
            if (!isset($data[$key]) || $data[$key] === '' || $data[$key] === null) continue;

            $resolved = $this->resolveBlobField($key, $data[$key]);
            if ($resolved !== null) {
                $data[$key] = $resolved;
            } else {
                unset($data[$key]);
            }
        }

        return $data;
    }

    /**
     * Attempt to resolve a single CSV value as a blob.
     * Returns a blob array on success, or null if resolution fails.
     */
    private function resolveBlobField(string $key, string $value): ?array
    {
        // ── JSON inline: {"data":"...","type":"...","name":"...","size":...} ──────
        if (str_starts_with(trim($value), '{')) {
            $decoded = json_decode($value, true);
            if (is_array($decoded) && isset($decoded['data'])) {
                return [
                    'data' => $decoded['data'],
                    'type' => $decoded['type'] ?? 'application/octet-stream',
                    'name' => $decoded['name'] ?? $key,
                    'size' => isset($decoded['size']) ? (int) $decoded['size'] : null,
                ];
            }
            $message = "SeederHelpers: invalid JSON blob for field [{$key}], field set to NULL.";
            $this->command?->warn($message);
            Log::warning($message);
            return null;
        }

        // ── data URI: data:<mime>;base64,<payload> ───────────────────────────────
        if (str_starts_with($value, 'data:')) {
            if (preg_match('/^data:([^;]+);base64,(.+)$/s', $value, $m)) {
                $binary = base64_decode($m[2]);
                if ($binary === false) {
                    $message = "SeederHelpers: could not decode data URI for field [{$key}], field set to NULL.";
                    $this->command?->warn($message);
                    Log::warning($message);
                    return null;
                }
                return [
                    'data' => $m[2],
                    'type' => $m[1],
                    'name' => $key,
                    'size' => strlen($binary),
                ];
            }
            $message = "SeederHelpers: malformed data URI for field [{$key}], field set to NULL.";
            $this->command?->warn($message);
            Log::warning($message);
            return null;
        }

        // ── filesystem path ──────────────────────────────────────────────────────
        $looksLikePath = str_contains($value, DIRECTORY_SEPARATOR)
            || str_contains($value, '/')
            || preg_match('/\.[a-zA-Z0-9]{1,10}$/', $value);

        if ($looksLikePath) {
            $resolved = str_starts_with($value, '/') ? $value : base_path($value);

            if (File::exists($resolved)) {
                $binary = File::get($resolved);
                return [
                    'data' => base64_encode($binary),
                    'type' => mime_content_type($resolved) ?: 'application/octet-stream',
                    'name' => basename($resolved),
                    'size' => strlen($binary),
                ];
            }

            $message = "SeederHelpers: blob file not found, field [{$key}] set to NULL: {$resolved}";
            $this->command?->warn($message);
            Log::warning($message);
            return null;
        }

        // ── plain base64 ─────────────────────────────────────────────────────────
        $binary = base64_decode($value, strict: true);
        if ($binary !== false) {
            return [
                'data' => $value,
                'type' => 'application/octet-stream',
                'name' => $key,
                'size' => strlen($binary),
            ];
        }

        $message = "SeederHelpers: could not resolve blob value for field [{$key}], field set to NULL.";
        $this->command?->warn($message);
        Log::warning($message);
        return null;
    }

    private function seedManyToManyFromCsv(string $modelClass, string $relatedClass, string $relationName): bool
    {
        $csvPath = database_path("seeders/csv/" . ((new \ReflectionClass($modelClass))->getShortName()) . "_" . ((new \ReflectionClass($relatedClass))->getShortName()) . ".csv");
        if (!File::exists($csvPath)) return false;

        $csv = array_map('str_getcsv', file($csvPath));
        $headers = array_shift($csv);

        $grouped = [];
        foreach ($csv as $row) {
            if (empty(array_filter($row))) continue;
            $data = array_combine($headers, $row);
            $grouped[$data['model_id']][] = $data['related_id'];
        }

        foreach ($grouped as $modelId => $relatedIds) {
            $model = $modelClass::find($modelId);
            if ($model) $model->$relationName()->attach($relatedIds);
        }
        return true;
    }
}
