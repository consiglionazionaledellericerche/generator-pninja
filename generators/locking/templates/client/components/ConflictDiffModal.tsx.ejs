import { useTranslation } from 'react-i18next';
import type { ConflictData } from '../hooks/useRecordLock';

interface ConflictDiffModalProps {
  conflict: ConflictData;
  onKeepMine: () => void;
  onUseServer: () => void;
  onDismiss: () => void;
}

export function ConflictDiffModal({ conflict, onKeepMine, onUseServer, onDismiss }: ConflictDiffModalProps) {
  const { t } = useTranslation('locking');

  const fields = Array.from(new Set([
    ...Object.keys(conflict.clientVersion),
    ...Object.keys(conflict.serverVersion),
  ]));

  const changedFields = fields.filter(
    f => JSON.stringify(conflict.clientVersion[f]) !== JSON.stringify(conflict.serverVersion[f])
  );

  return (
    <div role="dialog" aria-modal="true" aria-labelledby="conflict-title">
      <h2 id="conflict-title">{t('conflict.title')}</h2>
      <p>{t('conflict.description')}</p>

      <table aria-label={t('conflict.diffTable')}>
        <thead>
          <tr>
            <th scope="col">{t('conflict.field')}</th>
            <th scope="col">{t('conflict.yourVersion')}</th>
            <th scope="col">{t('conflict.serverVersion')}</th>
          </tr>
        </thead>
        <tbody>
          {changedFields.map(field => (
            <tr key={field}>
              <td>{field}</td>
              <td className="conflict-diff__mine">
                {String(conflict.clientVersion[field] ?? '—')}
              </td>
              <td className="conflict-diff__server">
                {String(conflict.serverVersion[field] ?? '—')}
              </td>
            </tr>
          ))}
        </tbody>
      </table>

      <div className="conflict-diff__actions">
        <button type="button" onClick={onKeepMine}>{t('conflict.keepMine')}</button>
        <button type="button" onClick={onUseServer}>{t('conflict.useServer')}</button>
        <button type="button" onClick={onDismiss}>{t('conflict.dismiss')}</button>
      </div>
    </div>
  );
}