import { useTranslation } from 'react-i18next';
import type { LockStatus } from '../hooks/useRecordLock';

interface LockBannerProps {
  lockStatus: LockStatus;
  onForceRelease?: () => void;
  isAdmin?: boolean;
}

export function LockBanner({ lockStatus, onForceRelease, isAdmin }: LockBannerProps) {
  const { t } = useTranslation('locking');

  if (lockStatus.state !== 'locked') return null;

  const expiresAt = new Date(lockStatus.expiresAt).toLocaleTimeString();

  return (
    <div role="alert" aria-live="polite" className="lock-banner">
      <span className="lock-banner__icon" aria-hidden="true">🔒</span>
      <span className="lock-banner__message">
        {t('lockedBy', { user: lockStatus.lockedBy, expires: expiresAt })}
      </span>
      {isAdmin && onForceRelease && (
        <button
          type="button"
          className="lock-banner__force"
          onClick={onForceRelease}
        >
          {t('forceRelease')}
        </button>
      )}
    </div>
  );
}