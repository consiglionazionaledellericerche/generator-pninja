<?php

namespace App\Traits;

use App\Models\RecordLock;
use Illuminate\Database\Eloquent\Relations\MorphOne;

trait Lockable
{
    public function recordLock(): MorphOne
    {
        return $this->morphOne(RecordLock::class, 'lockable');
    }

    public function lockedByOther(string $username): ?string
    {
        $lock = $this->recordLock;
        if (!$lock) return null;
        if ($lock->isExpired()) return null;
        if ($lock->user_id === $username) return null;
        return $lock->user_id;
    }

    public function isLockedBy(string $username): bool
    {
        $lock = $this->recordLock;
        if (!$lock || $lock->isExpired()) return false;
        return $lock->user_id === $username;
    }
}