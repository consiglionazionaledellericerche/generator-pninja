function isEmpty(obj) {
  for (let key in obj) {
    return false;
  }
  return true;
}
function stripBlobData(fileFields, to) {
    if (!fileFields.length) return '';
    const lines = fileFields.map(field => `            foreach ($data['data'] as &$item) {
                if (!empty($item['${to.snake(field)}'])) {
                    $item['${to.snake(field)}'] = array_diff_key($item['${to.snake(field)}'], ['data' => '']);
                }
            }
            unset($item);`).join('\n');
    return `$data = $result->toArray();
${lines}
            return response()->json($data);`;
}
