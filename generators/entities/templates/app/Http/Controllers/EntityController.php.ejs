<%  if(fileFields.length) {-%>
    public function serveBlob($id, string $field)
    {
        try {
            $<%- entityName %> = <%- className %>::findOrFail($id);

            $blob = $<%- entityName %>->$field;

            if (!$blob || empty($blob['data'])) {
                return response()->json(['error' => 'File not found'], 404);
            }

            return response(base64_decode($blob['data']), 200)
                ->header('Content-Type', $blob['type'] ?? 'application/octet-stream')
                ->header('Content-Disposition', 'inline; filename="' . ($blob['name'] ?? 'file') . '"');

        } catch (\Exception $e) {
            return $this->handleShowError($e);
