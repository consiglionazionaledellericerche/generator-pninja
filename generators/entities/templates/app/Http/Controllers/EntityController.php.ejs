            } else {
                $result = <%- className %><%- withs ? `::with(${withs})` : '::query()' %>
<%  if (relatedEntitiesForFilters && relatedEntitiesForFilters.length) {-%>
                    ->whereNotIn('id', $excludeIds)
<%  }-%>
                    ->orderBy($sortBy, $sortDirection)
                    ->paginate($perPage);
            }
<%  } else { -%>
            $result = <%- className %><%- withs ? `::with(${withs})` : '::query()' %>
<%      if (relatedEntitiesForFilters && relatedEntitiesForFilters.length) {-%>
                ->whereNotIn('id', $excludeIds)
<%      }-%>
                ->orderBy($sortBy, $sortDirection)
                ->paginate($perPage);
<%  } -%>
<%  if (fileFields.length) { -%>
