                $excludeIds = <%-name%>::whereNotNull('<%-to.snake(injectedField)%>_id')
                    ->when($<%-to.camel(name)%>Id, function($query) use ($<%-to.camel(name)%>Id) {
                        return $query->where('id', '!=', $<%-to.camel(name)%>Id);
                    })
