<?php

namespace Database\Seeders;

use Illuminate\Database\Seeder;
use Illuminate\Database\Console\Seeds\WithoutModelEvents;
use App\Traits\SeederHelpers;

class DatabaseSeeder extends Seeder
{
    use WithoutModelEvents, SeederHelpers;

    /**
     * Seed the application's database.
     */
    public function run(): void
    {
        $this->call([
<%  entities.forEach(function(entity) { -%>
            <%= entity.name %>Seeder::class,
<%  }); -%>
        ]);

<% manyToMany.forEach(function(rel) { -%>
        $this->seedManyToManyFromCsv(\App\Models\<%= rel.fromEntity %>::class, \App\Models\<%= rel.toEntity %>::class, '<%= rel.relPropery %>') || \App\Models\<%= rel.fromEntity %>::all()->each(fn($entity) => $entity-><%= rel.relPropery %>()->attach(\App\Models\<%= rel.toEntity %>::all()->random(rand(1, \App\Models\<%= rel.toEntity %>::count()))));
<% }); -%>
    }
}