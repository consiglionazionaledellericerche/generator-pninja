import axiosInstance from '../../shared/axiosInstance';
import { ApiResponsePage } from '../../types/api-response.types';
import { I<%= entity.name %> } from '../model/<%= to.slug(entity.name) %>.model';

export interface <%= entity.name %>ListParams {
  page: number;
  sort_by: string;
  sort_direction: string;
}

<% if (entity.softDelete) { -%>
export interface <%= entity.name %>TrashedListParams {
  page: number;
  sort_by: string;
  sort_direction: string;
}

<% } -%>
export const <%= entity.name %>Service = {
  list: (params: <%= entity.name %>ListParams) =>
    axiosInstance
      .get('/api/<%=to.slug(pluralize(entity.name))%>', { params })
      .then((r) => r.data as ApiResponsePage<I<%= entity.name %>>),
  get: (id: number) =>
    axiosInstance.get(`/api/<%=to.slug(pluralize(entity.name))%>/${id}`).then((r) => r.data as I<%= entity.name %>),
  create: (data: I<%= entity.name %>) =>
    axiosInstance.post('/api/<%=to.slug(pluralize(entity.name))%>', data).then((r) => r.data as I<%= entity.name %>),
  update: (id: number, data: I<%= entity.name %>) =>
    axiosInstance.put(`/api/<%=to.slug(pluralize(entity.name))%>/${id}`, data).then((r) => r.data as I<%= entity.name %>),
  remove: (id: number) =>
    axiosInstance.delete(`/api/<%=to.slug(pluralize(entity.name))%>/${id}`),
<% if (entity.softDelete) { -%>
  listTrashed: (params: <%= entity.name %>TrashedListParams) =>
    axiosInstance
      .get('/api/trashed-<%=to.slug(pluralize(entity.name))%>', { params })
      .then((r) => r.data as ApiResponsePage<I<%= entity.name %>>),
  restore: (id: number) =>
    axiosInstance.post('/api/trashed-<%=to.slug(pluralize(entity.name))%>/', { id }),
  forceDelete: (id: number) =>
    axiosInstance.delete(`/api/trashed-<%=to.slug(pluralize(entity.name))%>/${id}`),
<% } -%>
<% if (entity.pessimisticLock) { -%>
  acquireLock: (id: number) =>
    axiosInstance.post(`/api/locks/<%=to.slug(pluralize(entity.name))%>/${id}/acquire`),
  renewLock: (id: number) =>
    axiosInstance.post(`/api/locks/<%=to.slug(pluralize(entity.name))%>/${id}/renew`),
  removeLock: (id: number) =>
    axiosInstance.delete(`/api/locks/<%=to.slug(pluralize(entity.name))%>/${id}`),
  lockStatus: (id: number) =>
    axiosInstance.get(`/api/locks/<%=to.slug(pluralize(entity.name))%>/${id}`),
<% } -%>
};
