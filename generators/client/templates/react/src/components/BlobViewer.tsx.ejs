      href={objectUrl}
      target="_blank"
      rel="noopener noreferrer"
      className="text-sm text-link truncate max-w-xs"
    >
      {name}
    </a>
  </div>
);

// ─── Audio viewer ─────────────────────────────────────────────────────────────

const AudioViewer: React.FC<{ objectUrl: string; name: string }> = ({ objectUrl, name }) => (
  <div className="flex items-center gap-2">
    <Icon icon="audio_file" size={8} className="text-gray-400" />
    <a
      href={objectUrl}
      target="_blank"
