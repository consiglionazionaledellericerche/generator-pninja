import React, { useEffect, useState } from 'react';
import { useTranslation } from 'react-i18next';
import { Icon } from './Icon';

type BlobValue = {
  data: string;
  type: string;
  name: string;
  size?: number | null;
};

const INLINE_IMAGE_TYPES = [
  'image/jpeg',
  'image/png',
  'image/gif',
  'image/webp',
  'image/svg+xml',
  'image/avif',
  'image/apng',
];

function base64ToUint8Array(base64: string): Uint8Array {
  const binary = atob(base64);
  const bytes = new Uint8Array(binary.length);
  for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
  return bytes;
}

// ─── Image viewer ────────────────────────────────────────────────────────────

const ImageViewer: React.FC<{ objectUrl: string; name: string }> = ({ objectUrl, name }) => (
  <a href={objectUrl} target="_blank" rel="noopener noreferrer">
    <img
      src={objectUrl}
      alt={name}
      className="max-w-xs max-h-80 rounded border border-gray-200 dark:border-gray-700"
    />
  </a>
);

// ─── Video viewer ────────────────────────────────────────────────────────────

const VideoViewer: React.FC<{ objectUrl: string; name: string }> = ({ objectUrl, name }) => (
  <a
    href={objectUrl}
    target="_blank"
    rel="noopener noreferrer"
    className="h-full inline-block relative"
  >
    <video
      src={objectUrl}
      preload="metadata"
      className="max-w-xs max-h-80 rounded border border-gray-200 dark:border-gray-700"
    />
    <div className="absolute inset-0 flex items-center justify-center bg-black/30">
      <Icon icon="play_circle" size={12} className="text-white drop-shadow" />
    </div>
  </a>
);

// ─── PDF viewer ──────────────────────────────────────────────────────────────

const PdfViewer: React.FC<{ blob: BlobValue; objectUrl: string }> = ({ blob, objectUrl }) => {
  const [thumbnailUrl, setThumbnailUrl] = useState<string | null>(null);
  const [pdfError, setPdfError] = useState(false);

  useEffect(() => {
    let cancelled = false;

    const render = async () => {
      try {
        const pdfjsLib = await import('pdfjs-dist');
        pdfjsLib.GlobalWorkerOptions.workerSrc = new URL(
          'pdfjs-dist/build/pdf.worker.mjs',
          import.meta.url
        ).toString();

        const bytes = base64ToUint8Array(blob.data);
        const pdf = await pdfjsLib.getDocument({ data: bytes }).promise;
        const page = await pdf.getPage(1);
        const viewport = page.getViewport({ scale: 1 });

        // Scale to fit within 320px wide
        const scale = Math.min(1, 320 / viewport.width);
        const scaledViewport = page.getViewport({ scale });

        const canvas = document.createElement('canvas');
        canvas.width = scaledViewport.width;
        canvas.height = scaledViewport.height;

        await page.render({
          canvasContext: canvas.getContext('2d')!,
          viewport: scaledViewport,
          canvas,
        }).promise;

        if (cancelled) return;

        canvas.toBlob((canvasBlob) => {
          if (!canvasBlob) return;
          const url = URL.createObjectURL(canvasBlob);
          if (cancelled) {
            URL.revokeObjectURL(url);
          } else {
            setThumbnailUrl((prev) => {
              if (prev) URL.revokeObjectURL(prev);
              return url;
            });
          }
        }, 'image/png');
      } catch {
        if (!cancelled) setPdfError(true);
      }
    };

    render();

    return () => {
      cancelled = true;
    };
  }, [blob.data]);

  return (
    <>
      {thumbnailUrl && !pdfError && (
        <a href={objectUrl} target="_blank" rel="noopener noreferrer" className="block">
          <img
            src={thumbnailUrl}
            alt={blob.name}
            className="max-w-xs rounded border border-gray-200 dark:border-gray-700"
          />
        </a>
      )}
      {(pdfError || !thumbnailUrl) && (
        <Icon icon="picture_as_pdf" size={10} className="text-red-500" />
      )}
    </>
  );
};

// ─── Generic file viewer ─────────────────────────────────────────────────────

const GenericViewer: React.FC<{ objectUrl: string; name: string }> = ({ objectUrl, name }) => (
  <div className="flex items-center gap-2">
