import { useEffect, useState, useMemo, useRef } from 'react';
import { useTranslation } from 'react-i18next';
import { Icon } from '../Icon';
import { RegisterOptions, FieldValues } from 'react-hook-form';
import { useFormContext, useController } from 'react-hook-form';
import { FormLabel, FormErrors, FormFieldInfo } from './index';
import {
  Button,
  TextField as TextFieldAria,
  Input,
  TextFieldProps as TextFieldPropsAria,
} from 'react-aria-components';

interface PasswordFieldProps
  extends Omit<TextFieldPropsAria, 'type' | 'isInvalid' | 'isRequired' | 'children'> {
  fieldName: string;
  label: string;
  placeholder?: string;
  mode?: 'password' | 'passphrase';
  validations?: {
    required?: boolean;
    strength?: boolean;
    minlength?: number;
    maxlength?: number;
    minwords?: number;
  };
  showGenerator?: boolean;
}

type PasswordStrengthLevel = 'weak' | 'medium' | 'strong';

interface PasswordStrength {
  level: PasswordStrengthLevel;
  score: number;
  isStrong: boolean;
}

const SPECIAL_CHARS_REGEX = /[!"#$%&'()*+,-./:;<=>?@[\\\]^_`{|}~]/;
const SPECIAL_CHARS = '!"#$%&\'()*+,-./:;<=>?@[\\]^_`{|}~';
const UPPERCASE = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
const LOWERCASE = 'abcdefghijklmnopqrstuvwxyz';
const NUMBERS = '0123456789';
const ALL_CHARS = UPPERCASE + LOWERCASE + NUMBERS + SPECIAL_CHARS;

let cachedWordlist: string[] | null = null;

const loadWordlist = async (): Promise<string[]> => {
  if (cachedWordlist) return cachedWordlist;
  const res = await fetch('/wordlists/eff_large.txt');
  if (!res.ok) throw new Error('Failed to fetch wordlist');
  const text = await res.text();
  cachedWordlist = text.split('\n').filter(Boolean);
  return cachedWordlist;
};

const generateSecurePassword = (length: number): string => {
  const password: string[] = [];

  const getRandomChar = (chars: string): string => {
    const array = new Uint32Array(1);
    crypto.getRandomValues(array);
    return chars[array[0] % chars.length];
  };

  password.push(getRandomChar(UPPERCASE));
  password.push(getRandomChar(LOWERCASE));
  password.push(getRandomChar(NUMBERS));
  password.push(getRandomChar(SPECIAL_CHARS));

  for (let i = password.length; i < length; i++) {
    password.push(getRandomChar(ALL_CHARS));
  }

  for (let i = password.length - 1; i > 0; i--) {
    const array = new Uint32Array(1);
    crypto.getRandomValues(array);
    const j = array[0] % (i + 1);
    [password[i], password[j]] = [password[j], password[i]];
  }

  return password.join('');
};

const generatePassphrase = (wordlist: string[], wordCount: number): string => {
  const words: string[] = [];
  for (let i = 0; i < wordCount; i++) {
    const array = new Uint32Array(1);
    crypto.getRandomValues(array);
    words.push(wordlist[array[0] % wordlist.length]);
  }
  return words.join('-');
};

const calculatePasswordStrength = (password: string, minLength: number): PasswordStrength => {
  const criteria = {
    minLength: password.length >= minLength,
    hasUppercase: /[A-Z]/.test(password),
    hasLowercase: /[a-z]/.test(password),
    hasNumbers: /\d/.test(password),
    hasSpecialChars: SPECIAL_CHARS_REGEX.test(password),
  };

  const score = Object.values(criteria).filter(Boolean).length;
  const isStrong = score === 5;

  let level: PasswordStrengthLevel;
  if (score <= 2) level = 'weak';
  else if (score <= 4) level = 'medium';
  else level = 'strong';

  return { level, score, isStrong };
};

const countWords = (value: string): number =>
  value.trim()
    ? value
        .trim()
        .split(/[\s-]+/)
        .filter(Boolean).length
    : 0;

const PasswordField: React.FC<PasswordFieldProps> = ({
  fieldName,
  label,
  validations,
  mode = 'password',
  showGenerator = true,
  ...props
}) => {
  const { t } = useTranslation();
  const {
    required,
    strength = mode === 'password',
    minlength = 10,
    maxlength,
    minwords = 5,
  } = validations || {};

  const { control, setValue } = useFormContext();
  const rules: RegisterOptions<FieldValues, string> = {};
  const [showPassword, setShowPassword] = useState(false);
  const [copied, setCopied] = useState(false);
  const wordlistRef = useRef<string[] | null>(null);

  if (required) {
    rules.required = 'errors.validations.required';
  }

  if (mode === 'passphrase') {
    rules.validate = {
      minWords: (value: string) => {
        const words = countWords(value);
        return words >= minwords || `errors.validations.passphrase.minwords:${minwords}`;
      },
      ...(minlength && {
        minLength: (value: string) =>
          value.length >= minlength || `errors.validations.minlength:${minlength}`,
      }),
      ...(maxlength && {
        maxLength: (value: string) =>
          value.length <= maxlength || `errors.validations.maxlength:${maxlength}`,
      }),
    };
  } else {
    if (!strength && minlength) {
      rules.minLength = {
        value: minlength,
        message: `errors.validations.minlength:${minlength}`,
      };
    }
    if (maxlength) {
      rules.maxLength = {
        value: maxlength,
        message: `errors.validations.maxlength:${maxlength}`,
      };
    }
    if (strength) {
      rules.validate = {
        strength: (value: string) => {
          const strengthResult = calculatePasswordStrength(value, minlength);
          return strengthResult.isStrong || 'errors.validations.password.weakPassword';
        },
      };
    }
  }

  const {
    field,
    fieldState: { error },
  } = useController({
    name: fieldName,
    control,
    rules,
  });

  const passwordStrength = useMemo(
    () =>
      mode === 'password' && strength
        ? calculatePasswordStrength(field.value || '', minlength)
        : null,
    [field.value, mode, strength, minlength]
  );

  const wordCount = useMemo(
    () => (mode === 'passphrase' && field.value ? countWords(field.value) : 0),
    [field.value, mode]
  );

  const handleGeneratePassword = () => {
    const newPassword = generateSecurePassword(minlength);
    setValue(fieldName, newPassword, { shouldValidate: true, shouldDirty: true });
  };

  const handleGeneratePassphrase = async () => {
    try {
      if (!wordlistRef.current) {
        wordlistRef.current = await loadWordlist();
      }
      const newPassphrase = generatePassphrase(wordlistRef.current, minwords);
      setValue(fieldName, newPassphrase, { shouldValidate: true, shouldDirty: true });
    } catch {
      // fetch failed: user types manually
    }
  };

  const handleGenerate = mode === 'passphrase' ? handleGeneratePassphrase : handleGeneratePassword;

  useEffect(() => {
    if (!copied) return;
    const timeout = setTimeout(() => setCopied(false), 2000);
    return () => clearTimeout(timeout);
  }, [copied]);

  const handleCopyPassword = async () => {
    if (field.value) {
      try {
        await navigator.clipboard.writeText(field.value);
        setCopied(true);
      } catch (err) {
        console.error('Failed to copy password:', err);
      }
    }
  };

  return minlength < 8 ? (
    <p className="font-mono text-red-600 dark:text-red-500">
      PasswordField definition error: minlength must be greater than or equal to 8
    </p>
  ) : maxlength && maxlength < minlength ? (
    <p className="font-mono text-red-600 dark:text-red-500">
      PasswordField definition error: maxlength must be greater than or equal to minlength
    </p>
  ) : mode === 'passphrase' && minwords < 4 ? (
    <p className="font-mono text-red-600 dark:text-red-500">
      PasswordField definition error: minwords must be greater than or equal to 4
    </p>
  ) : (
    <TextFieldAria
      {...props}
      isInvalid={!!error}
      isRequired={required}
      className={`group ${props.className ? ` ${props.className}` : ''}`}
      type={showPassword ? 'text' : 'password'}
    >
      <FormLabel validations={validations}>{label}</FormLabel>
      <div
        className={`flex items-center gap-1
    focus-within:outline-2
    focus-within:outline-offset-2 focus-within:outline-blue-600 focus-within:dark:outline-sky-300 rounded-md w-full border-none bg-slate-200 text-slate-800 dark:bg-slate-600 dark:text-slate-200 placeholder-slate-600 dark:placeholder-slate-300 text-sm/6 py-1.5 px-3
    group-data-invalid:focus-within:inset-ring-0 group-data-invalid:focus-within:outline-2 group-data-invalid:focus-within:outline-offset-2 group-data-invalid:focus-within:outline-red-600 group-data-invalid:dark:focus-within:outline-red-500
    group-data-invalid:inset-ring-2 group-data-invalid:inset-ring-red-600 group-data-invalid:dark:inset-ring-red-500
          `}
      >
        <Input
          {...field}
          value={field.value || ''}
          className="outline-0 flex-1 border-none placeholder-slate-600 dark:placeholder-slate-300 font-[inherit]"
        />

        {showGenerator && !props.isDisabled && !props.isReadOnly && (
          <Button
            onClick={handleGenerate}
            className="text-sm text-center transition rounded-full border-0 p-1 flex items-center justify-center text-slate-600 dark:text-slate-300 bg-transparent hover:bg-black/15 pressed:bg-black/10 size-6"
          >
            <span className="sr-only">
              {mode === 'passphrase' ? t('passphrase.generate') : t('password.generate')}
            </span>
            <Icon
              icon="password_2"
              fill
              size={5}
              title={mode === 'passphrase' ? t('passphrase.generate') : t('password.generate')}
            />
          </Button>
        )}

        {field.value && (
          <Button
            onClick={handleCopyPassword}
            className="text-sm text-center transition rounded-full border-0 p-1 flex items-center justify-center text-slate-600 dark:text-slate-300 bg-transparent hover:bg-black/15 pressed:bg-black/10 size-6"
          >
            <span className="sr-only">{copied ? t('password.copied') : t('password.copy')}</span>
            {copied ? (
              <Icon
                icon="check"
                size={5}
                className="text-green-600 dark:text-green-400"
                title={t('password.copied')}
              />
            ) : (
              <Icon icon="content_copy" size={5} title={t('password.copy')} />
            )}
          </Button>
        )}

        <Button
          onClick={() => setShowPassword(!showPassword)}
          className="text-sm text-center transition rounded-full border-0 p-1 flex items-center justify-center text-slate-600 dark:text-slate-300 bg-transparent hover:bg-black/15 pressed:bg-black/10 size-6 group-empty:invisible"
        >
          <span className="sr-only">
            {showPassword ? t('actions.hidePassword') : t('actions.showPassword')}
          </span>
          <Icon
            title={showPassword ? t('actions.hidePassword') : t('actions.showPassword')}
            icon={showPassword ? 'visibility_off' : 'visibility'}
            fill={!showPassword}
            size={5}
          />
        </Button>
      </div>

      {/* Password strength indicator */}
      {mode === 'password' && strength && field.value && passwordStrength && (
        <div className="mt-2">
          <div
            role="progressbar"
            aria-valuenow={passwordStrength.score}
            aria-valuemin={0}
            aria-valuemax={5}
            aria-label={t('password.strengthLabel')}
            className="h-2 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden"
          >
            <div
              className={`h-full transition-all duration-300 ${
                passwordStrength.level === 'weak'
                  ? 'bg-red-500 w-1/3'
                  : passwordStrength.level === 'medium'
                    ? 'bg-yellow-700 dark:bg-yellow-500 w-2/3'
                    : 'bg-green-600 dark:bg-green-500 w-full'
              }`}
            />
          </div>

          <p
            className={`text-sm mt-1 font-medium ${
              passwordStrength.level === 'weak'
                ? 'text-red-600 dark:text-red-400'
                : passwordStrength.level === 'medium'
                  ? 'text-yellow-600 dark:text-yellow-400'
                  : 'text-green-600 dark:text-green-400'
            }`}
            aria-live="polite"
          >
            {t(`password.strength.${passwordStrength.level}`)}
          </p>

          <ul
            className={`text-sm mt-2 space-y-1 ${
              passwordStrength.level === 'weak'
                ? 'text-red-600 dark:text-red-400'
                : passwordStrength.level === 'medium'
                  ? 'text-yellow-600 dark:text-yellow-400'
                  : 'text-green-600 dark:text-green-400'
            }`}
            role="list"
          >
            <li className="flex items-center gap-1">
              <Icon
                fill
                size="xl"
                icon={
                  passwordStrength.level === 'weak'
                    ? 'error'
                    : passwordStrength.level === 'medium'
                      ? 'warning'
                      : 'check'
                }
              />{' '}
              {t('password.criteria.minLength', { count: minlength })}
            </li>
            <li className="flex items-center gap-1">
              <Icon
                fill
                size="xl"
                icon={
                  passwordStrength.level === 'weak'
                    ? 'error'
                    : passwordStrength.level === 'medium'
                      ? 'warning'
                      : 'check'
                }
              />{' '}
              {t('password.criteria.uppercase')}
            </li>
            <li className="flex items-center gap-1">
              <Icon
                fill
                size="xl"
                icon={
                  passwordStrength.level === 'weak'
                    ? 'error'
                    : passwordStrength.level === 'medium'
                      ? 'warning'
                      : 'check'
                }
              />{' '}
              {t('password.criteria.lowercase')}
            </li>
            <li className="flex items-center gap-1">
              <Icon
                fill
                size="xl"
                icon={
                  passwordStrength.level === 'weak'
                    ? 'error'
                    : passwordStrength.level === 'medium'
                      ? 'warning'
                      : 'check'
                }
              />{' '}
              {t('password.criteria.numbers')}
            </li>
            <li className="flex items-center gap-1">
              <Icon
                fill
                size="xl"
                icon={
                  passwordStrength.level === 'weak'
                    ? 'error'
                    : passwordStrength.level === 'medium'
                      ? 'warning'
                      : 'check'
                }
              />{' '}
              {t('password.criteria.specialChars')}
            </li>
          </ul>
        </div>
      )}

      {/* Passphrase word count indicator */}
      {mode === 'passphrase' && field.value && (
        <p
          className={`text-sm mt-1 font-medium ${
            wordCount >= minwords
              ? 'text-green-600 dark:text-green-400'
              : 'text-red-600 dark:text-red-400'
          }`}
          aria-live="polite"
        >
          {t('passphrase.wordCount', { count: wordCount, min: minwords })}
        </p>
      )}

      {!error && <FormFieldInfo validations={validations || {}} />}
      <FormErrors error={error} />
    </TextFieldAria>
  );
};

export { PasswordField };
