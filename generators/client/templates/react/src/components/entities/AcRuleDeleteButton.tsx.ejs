import { useTranslation } from 'react-i18next';
import { AxiosError } from 'axios';
import { ErrorResponseData, useNotifications } from '../../contexts/NotificationContext';
import ConfirmButton from '../ConfirmButton';
import import { AcRuleService } from '../../shared/services/ac-rule.service';

interface DeleteButtonProps {
  id: string | number | null | undefined;
}

const AcRuleDeleteButton: React.FC<DeleteButtonProps> = ({
  id,
  disabled = false,
  onConfirm = () => {},
  onDelete = () => {},
  onError = () => {},
}) => {
  const { t } = useTranslation();

  const navigate = useNavigate();
  const { addNotification } = useNotifications();

  const deleteRecord = (id: string | number | null | undefined) => {
    if (!id) return;
    AcRuleService.remove(Number(id))
      .then(() => {
        addNotification({
          type: 'success',
          message: t(`actions.crud.successfullyDeleted`, { id }),
        });
        onDelete();
      })
      .catch((error: AxiosError<ErrorResponseData>) => {
        addNotification({
          type: 'error',
          message: `${t('errors.entities.delete')} ${t('entities:ac_rule.AcRule')} ID ${id}`,
          error,
        });
        onError();
      });
  };

  return (
    <ConfirmButton
      disabled={disabled}
      onConfirm={() => {
        onConfirm();
        deleteRecord(Number(id));
      }}
      className="danger-button"
      pendingClassName="danger-button"
      label={t('actions.crud.delete')}
      pendingLabel={
        <span className="flex items-center gap-2">{t('actions.crud.confirmDelete')}</span>
      }
    />
  );
};
export default AcRuleDeleteButton;
