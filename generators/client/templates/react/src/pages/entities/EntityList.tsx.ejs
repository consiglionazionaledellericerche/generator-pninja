import { Link } from 'react-router-dom';
<%_ if (entity.pessimisticLock) { _%>
import { TooltipTrigger, Button } from 'react-aria-components';
import { Tooltip } from '../../components/Tooltip';
<%_ } _%>
import { Fragment, useCallback, useEffect, useState } from 'react';
import { useTranslation<%- entity.pessimisticLock ? ', Trans' : '' %> } from 'react-i18next';
import { ApiResponsePage, SortConfig } from '../../types/api-response.types';
import { ApiResponsePagination } from '../../components/ApiResponsePagination';
<% if(durationColumns.length) {-%>
import { DurationFieldViewer } from '../../components/formElements/DurationField';
<% } -%>
import { TableSkeletonLoader } from '../../components/TableSkeletonLoader';
<% if (searchEngine !== 'null' ) { -%>
import { SearchInput } from '../../components/SearchInput';
<% } -%>
import { I<%= entity.name %> } from '../../shared/model/<%= to.slug(entity.name)%>.model';
import { AxiosError } from 'axios';
import { ErrorResponseData, useNotifications } from '../../contexts/NotificationContext';
import { <%= entity.name %>Service } from '../../shared/services/<%= to.slug(entity.name) %>.service';
import useAutoShortcuts from '../../hooks/useAutoShortcuts';
import { detect } from 'detect-browser';
import { Can } from '../../components/Can';
import { Icon } from '../../components/Icon';
import { IconEntity<%= entity.name %> } from '../../shared/entitiesIcons';
const isMac = detect()?.os?.toLowerCase().includes('mac');

type SortableField = 'id'<%for(column of columns) { %><% if (!fileColumns.includes(column)) { %> | '<%=column%>'<% } %><% } %>;

export default function <%= entity.name %>List() {
  const { t, i18n } = useTranslation();
  const { addNotification } = useNotifications();
  const [loading, setLoading] = useState(false);
<%_ if (entity.pessimisticLock) { _%>
  const [lockMap, setLockMap] = useState<Map<number, { lockedBy: string; expiresAt: string }>>(new Map());
<%_ } _%>
<% if (searchEngine !== 'null' ) { -%>
  const [searchTerm, setSearchTerm] = useState('');
  const [debouncedSearchTerm, setDebouncedSearchTerm] = useState('');
<% } -%>
  const [sortConfig, setSortConfig] = useState<SortConfig<SortableField>>({
    field: 'id',
    direction: 'asc',
  });
  const [currentPage, setCurrentPage] = useState(1);
  const [page, setPage] = useState<ApiResponsePage<I<%= entity.name %>> | null>(null);
  useAutoShortcuts();
  const sortableColumns: SortableField[] = [
    'id',
<%for(column of columns) { -%>
<%  if (!fileColumns.includes(column)) { -%>
    '<%=column%>',
<%  }-%>
<%}-%>
  ];

  const loadRecords = useCallback(() => {
    setLoading(true);
    <%= entity.name %>Service.list({
      page: currentPage,
      sort_by: sortConfig.field,
      sort_direction: sortConfig.direction,
<% if (searchEngine !== 'null' ) { -%>
      ...(debouncedSearchTerm ? { search: debouncedSearchTerm } : {}),
<% } -%>
    })
      .then((data: ApiResponsePage<I<%= entity.name %>>) => {
        setPage(data);
        setLoading(false);
      })
      .catch((error: AxiosError<ErrorResponseData>) => {
        setLoading(false);
        addNotification({
          type: 'error',
          message: error.message,
          error,
        });
      });
  }, [addNotification, sortConfig, currentPage<% if (searchEngine !== 'null' ) { -%>, debouncedSearchTerm<% } -%>]);

  const handleSort = (field: SortableField) => {
    setSortConfig((currentConfig) => ({
      field,
      direction:
        currentConfig.field === field && currentConfig.direction === 'asc' ? 'desc' : 'asc',
    }));
    setCurrentPage(1);
  };
<% if (searchEngine !== 'null' ) { -%>

  useEffect(() => {
    const timeoutId = setTimeout(() => {
      setDebouncedSearchTerm(searchTerm);
      setCurrentPage(1);
    }, 300);
    return () => clearTimeout(timeoutId);
  }, [searchTerm]);
<% } -%>

  interface SortHeaderProps extends React.HTMLAttributes<HTMLTableCellElement> {
    field: string;
    label: string;
    className?: string;
  }

  const SortHeader: React.FC<SortHeaderProps> = ({ field, label, className, ...props }) => {
<%  if (searchEngine === 'algolia') {-%>
    if (debouncedSearchTerm) return <th scope="col">{label}</th>; // Algolia does its own sorting
<% } -%>
    const isSorted = sortConfig.field === field;
    const isSortable = sortableColumns.includes(field as SortableField);
    if (!isSortable) {
      return (
        <th scope="col" className={className ? className : ''} {...props}>
          {label}
        </th>
      );
    }
    return (
      <th
        scope="col"
        className={`${isSortable ? 'cursor-pointer select-none py-0! px-0!' : ''}${className ? ' ' + className : ''}`}
        onClick={() => isSortable && handleSort(field as SortableField)}
        {...props}
      >
        <button
          className="cursor-pointer flex items-center gap-4 w-full ps-6 py-3 text-nowrap truncate"
          aria-label={t(
            `common.sortBy.${isSorted && sortConfig.direction === 'asc' ? 'descending' : 'ascending'}`,
            {
              field: label,
            }
          )}
        >
          <div className="grow text-left">{label}</div>
          {isSorted && (
            <Icon
              icon={'keyboard_arrow_down'}
              size={5}
              className={sortConfig.direction !== 'asc' ? 'rotate-180 duration-100' : ''}
            />
          )}
          {!isSorted && <Icon icon="unfold_more" size={5} />}
        </button>
      </th>
    );
  };

  useEffect(() => loadRecords(), [loadRecords]);

<%_ if (entity.pessimisticLock) { _%>
  useEffect(() => {
    if (!page?.data?.length) return;
    Promise.all(
      page.data.map((row) =>
        <%= entity.name %>Service.lockStatus(row.id)
          .then(({ data }) => ({ id: row.id, data }))
          .catch(() => ({ id: row.id, data: { locked: false } }))
      )
    ).then((results) => {
      const map = new Map<number, { lockedBy: string; expiresAt: string }>();
      results.forEach(({ id, data }) => {
        if (data.locked) map.set(id, { lockedBy: data.locked_by, expiresAt: data.expires_at });
      });
      setLockMap(map);
    });
  }, [page]);

<%_ } _%>

  useEffect(() => {
    document.title = t('entities:<%-to.snake(entity.name)%>.<%- pluralize(entity.name)%>');
  }, [i18n.language, t]);

  return (
    <>
      <h1 className="flex items-center gap-2 text-2xl mb-4">
        <IconEntity<%=entity.name%> size={8} />
        {t('entities:<%-to.snake(entity.name)%>.<%- pluralize(entity.name)%>')}
      </h1>
      <div className={`flex gap-4 mb-4`}>
<% if (searchEngine !== 'null' ) { -%>
        <SearchInput onChange={(value) => setSearchTerm(value)} onClear={() => setSearchTerm('')} />
<% } -%>
        <Can resource="<%= entity.name %>" action="create">
          <Link
            to="/<%- entity.name === 'AcRule' ? 'admin' : 'entities' %>/<%=to.slug(pluralize(entity.name))%>/new"
            className="primary-button whitespace-nowrap"
            data-shortcut="ctrl+enter"
          >
            <Icon icon="add" size={5} />
            {t('actions.crud.create')} {t('entities:<%-to.snake(entity.name)%>.<%- entity.name%>')}
            <kbd className="kdb-shortcut">{isMac ? '⌘' : 'Ctrl'}</kbd>
            <kbd className="kdb-shortcut">↵</kbd>
          </Link>
        </Can>
      </div>
      <Fragment>
        <TableSkeletonLoader loading={loading} rows={10} cols={<%=columns.length - fileColumns.length + relatedEntities.length%>} />
      </Fragment>
      {!loading && page?.data && page?.data.length === 0 && (
        <p className="mb-4 text-2xl">{t('messages.noData')}</p>
      )}
      {!loading && page?.data && page?.data.length > 0 && (
        <>
          <div className="relative overflow-x-auto mb-4">
            <table className="data-table">
              <caption className="w-full text-left mb-2 text-sm font-normal">
                {t('pagination.summary', {
                  entity: t('entities:<%-to.snake(entity.name)%>.<%- pluralize(entity.name)%>'),
                  from: page?.from,
                  to: page?.to,
                  total: page?.total,
                })}
              </caption>
              <thead>
                <tr>
                  <SortHeader className="w-0" field="id" label={t('entities:<%-to.snake(entity.name)%>.id')} />
<%  for(column of columns) { -%>
                  <SortHeader field="<%-column%>" label={t('entities:<%-to.snake(entity.name)%>.<%-column%>')} />
<%  } -%>
<%                for(r of relatedEntities) { -%>
                  <th scope="col">{t('entities:<%-to.snake(entity.name)%>.<%-r.field%>')}</th>
<%                } -%>
                  <th scope="col">{t('actions.crud.actions')}</th>
                </tr>
              </thead>
              <tbody>
                {page?.data.map((row, key) => (
                  <tr key={key}>
                    <td className="w-0">
                      <Link className="text-link" to={`/<%- entity.name === 'AcRule' ? 'admin' : 'entities' %>/<%=to.slug(pluralize(entity.name))%>/view/${row.id}`}>
                        {row.id}
                      </Link>
                    </td>
<%                  for(column of columns) { -%>
<%                    if (!fileColumns.includes(column)) { -%>
                    <td><% if (!durationColumns.includes(column)) { %>{row.<%- column %>?.toString()}<% } else { %><DurationFieldViewer duration={row.<%- column %>} format="iso"/><% } %></td>
<%                    } else { -%>
                    <td>
                      <a
                        href={`/api/<%=to.slug(pluralize(entity.name))%>/${row.id}/<%- column %>/${row.<%- column %>_name}`}
                        className="text-link"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {row.<%- column %>_name?.toString()}
                      </a>
                    </td>
<%                    } -%>
<%                  } -%>
<%                  for(r of relatedEntities) { -%>
                    <td>
<%                  if(r.isArray) { -%>
                      {row?.<%-r.field%>?.map((row, index) => (<Fragment key={index}>{index !== 0 ? ', ': ''}<Link className="text-link" to={`/entities/<%=to.slug(pluralize(r.related))%>/view/${row?.id}`}>{row?.<%-to.snake(r.labelField)%>}</Link></Fragment>))}
<%                    } else { -%>
                      {row?.<%-r.field%>?.id && <Link className="text-link" to={`/entities/<%=to.slug(pluralize(r.related))%>/view/${row?.<%-r.field%>?.id}`}>{row?.<%-r.field%>?.<%-to.snake(r.labelField)%>}</Link>}
<%                    } -%>
                    </td>
<%                  } -%>
                    <td className="text-nowrap w-0 uppercase">
                      <div className="flex space-x-2">
                        <Can resource="<%= entity.name %>" action="read">
                          <Link to={`/<%- entity.name === 'AcRule' ? 'admin' : 'entities' %>/<%=to.slug(pluralize(entity.name))%>/view/${row.id}`} className="text-link">
                            {t('actions.crud.view')}
                          </Link>
                        </Can>
                        <Can resource="<%= entity.name %>" action="update">
<%_ if (entity.pessimisticLock) { _%>
                          {lockMap.has(row.id) ? (
                            <TooltipTrigger delay={500}>
                              <Button
                                className="text-amber-500 uppercase inline-flex items-center gap-1"
                                aria-label={t('locking:admin.columns.lock')}
                              >
                                <Icon icon="lock" size={5} className="text-amber-500" />
                                {t('locking:locked')}
                              </Button>
                              <Tooltip>
                                <Trans
                                  ns="locking"
                                  i18nKey="lockedBy"
                                  values={{
                                    user: lockMap.get(row.id)?.lockedBy,
                                    expires: new Date(
                                      lockMap.get(row.id)?.expiresAt ?? ''
                                    ).toLocaleString(),
                                  }}
                                  components={{
                                    strong: <strong />,
                                  }}
                                />
                              </Tooltip>
                            </TooltipTrigger>
                          ) : (
                            <Link to={`/<%- entity.name === 'AcRule' ? 'admin' : 'entities' %>/<%=to.slug(pluralize(entity.name))%>/edit/${row.id}`}className="text-link">{t('actions.crud.edit')}</Link>
                          )}
<%_ } else { _%>
                          <Link to={`/<%- entity.name === 'AcRule' ? 'admin' : 'entities' %>/<%=to.slug(pluralize(entity.name))%>/edit/${row.id}`} className="text-link">{t('actions.crud.edit')}</Link>
<%_ } _%>
                        </Can>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <ApiResponsePagination pageLinks={page.links || []} onSelectPage={setCurrentPage} />
        </>
      )}
    </>
  );
}